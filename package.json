{
  "name": "html-doc-editor",
  "displayName": "HTML Document Editor",
  "description": "WYSIWYG visual editor for static HTML files",
  "version": "0.1.1",
  "publisher": "yt3trees",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": ["html", "wysiwyg", "visual editor", "document", "editor"],
  "repository": {
    "type": "git",
    "url": "https://github.com/yt3trees/vscode-html-doc-editor"
  },
  "bugs": {
    "url": "https://github.com/yt3trees/vscode-html-doc-editor/issues"
  },
  "homepage": "https://github.com/yt3trees/vscode-html-doc-editor#readme",
  "license": "MIT",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "editHtml.visualEditor",
        "displayName": "HTML Document Editor",
        "selector": [
          {
            "filenamePattern": "*.html"
          }
        ],
        "priority": "option"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "vscode:prepublish": "node esbuild.mjs --minify"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "parse5": "^7.1.2"
  }
}
